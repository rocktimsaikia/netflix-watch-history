{
  "manifest_version": 3,
  "name": "Netflix Watch History",
  "version": "1.0.0",
  "description": "Adds a History button to the Netflix navbar linking to your viewing activity.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["content.js"]
    }
  ]
}
