{
  "manifest_version": 3,
  "name": "Watch History for Netflix",
  "version": "1.0.0",
  "description": "Adds a History button to the Netflix navbar linking to your viewing activity.",
  "browser_specific_settings": {
    "gecko": {
      "id": "watch-history-for-netflix@rocktimsaikia.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["content.js"]
    }
  ]
}
